# Configuration locale

OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=phi4-mini

LLM_PROVIDER=ollama
GEMINI_MODEL=gemini-3.5-flash
GEMINI_API_KEY=

AGENT_MEMORY_DIR=.agent_memory
AGENT_DB_PATH=
LOG_LEVEL=INFO
LOG_FILE=

API_HOST=127.0.0.1
API_PORT=8080

# Telegram
TELEGRAM_TOKEN=

# Scheduler
SCHED_USER_ID=local
SCHED_INGEST_SECONDS=3600
SCHED_DAILY_MINUTES=60
SCHED_WEEK_MINUTES=60
SCHED_WATCH=0
ENABLE_SCHEDULER_IN_API=0

# Runner
CHANNEL=all
# Autre option: all-cli pour garder un terminal interactif
# CHANNEL=all-cli
